---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Slowmotion">

  <!-- Hero -->
  <section class="home-hero">
    <div class="home-hero-bg"></div>
    <div class="home-hero-content">
      <h1>Het ontzichtbare<br />zichtbaar maken</h1>
      <p>met Super Slowmotion, Drones & Thermografie</p>
      <a href="/contact" class="btn-outline">Contact</a>
    </div>
  </section>

  <!-- Services grid -->
  <section class="services-grid">
    <a href="/art-of-slowmotion" class="service-tile">
      <div class="service-bg" style="background-image: url('/img/hero-home.jpg'); filter: brightness(0.35) saturate(0.5);"></div>
      <div class="service-content">
        <span class="service-label">Art of Slowmotion</span>
      </div>
    </a>
    <a href="/drone-operations" class="service-tile">
      <div class="service-bg" style="background-image: url('/img/home-section1.jpg'); filter: brightness(0.35) saturate(0.5);"></div>
      <div class="service-content">
        <span class="service-label">Drone Operations</span>
      </div>
    </a>
    <a href="/thermography" class="service-tile">
      <div class="service-bg" style="background-image: url('/img/home-section2.jpg'); filter: brightness(0.35) saturate(0.5);"></div>
      <div class="service-content">
        <span class="service-label">Thermography</span>
      </div>
    </a>
    <a href="/digital-services" class="service-tile">
      <div class="service-bg" style="background-image: url('/img/hero-home.jpg'); background-position: right center; filter: brightness(0.3) saturate(0.5);"></div>
      <div class="service-content">
        <span class="service-label">Digital Services</span>
      </div>
    </a>
  </section>

  <!-- Seeing the Unseen -->
  <section class="seeing-section">
    <div class="seeing-inner">
      <p class="seeing-quote">"Seeing the Unseen"</p>
      <p class="seeing-sub">Super Slowmotion&nbsp;&nbsp;·&nbsp;&nbsp;High Speed operator&nbsp;&nbsp;·&nbsp;&nbsp;Drone operations&nbsp;&nbsp;·&nbsp;&nbsp;Thermograaf</p>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .home-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding: 0 2rem 6rem;
    overflow: hidden;
  }

  .home-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/img/hero-home.jpg');
    background-size: cover;
    background-position: center;
  }

  .home-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,10,10,0.2) 0%,
      rgba(10,10,10,0.1) 40%,
      rgba(10,10,10,0.6) 100%
    );
  }

  .home-hero-content {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    width: 100%;
  }

  .home-hero-content h1 {
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 1.25rem;
  }

  .home-hero-content p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2.5rem;
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    height: 280px;
  }

  .service-tile {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    transition: transform 0.3s;
  }

  .service-tile:hover .service-bg {
    transform: scale(1.05);
    filter: brightness(0.5) saturate(0.5) !important;
  }

  .service-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .service-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
    width: 100%;
  }

  .service-label {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  /* Seeing the Unseen */
  .seeing-section {
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 5rem 2rem;
    text-align: center;
  }

  .seeing-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .seeing-quote {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .seeing-sub {
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .home-hero { padding: 0 1.25rem 4rem; }
    .services-grid { grid-template-columns: 1fr 1fr; height: auto; }
    .service-tile { height: 180px; }
    .seeing-section { padding: 4rem 1.25rem; }
  }

  @media (max-width: 480px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
