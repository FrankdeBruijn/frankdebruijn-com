---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <section class="hero">
    <h1>Het onzichtbare<br /><span>zichtbaar maken</span></h1>
    <p>Super Slowmotion · Drones · Thermografie</p>
    <a href="/contact" class="btn">Neem contact op</a>
  </section>

  <section class="section">
    <h2>Diensten</h2>
    <div class="card-grid">
      <a href="/art-of-slowmotion" class="card">
        <h3>Art of Slowmotion</h3>
        <p>Phantom high-speed cinematografie. Het onmogelijke vastleggen op meer dan 1000 fps.</p>
      </a>
      <a href="/drone-operations" class="card">
        <h3>Drone Operations</h3>
        <p>Professionele drone-inzet voor film, fotografie, mapping, FPV en inspecties. SPECIFIC-licentie.</p>
      </a>
      <a href="/thermography" class="card">
        <h3>Thermografie</h3>
        <p>Warmteverlies inzichtelijk maken via Warmtescan.nu. Quickscans, zonnepanelen, lekdetectie.</p>
      </a>
      <a href="/digital-services" class="card">
        <h3>Digital Services</h3>
        <p>Van concept tot digitale uitvoering. Websites, systemen en technische consultancy.</p>
      </a>
    </div>
  </section>

  <section class="section cta-section">
    <h2>Seeing the Unseen</h2>
    <p>Met meer dan 15 jaar ervaring in visuele technologie lever ik beelden en inzichten die anderen niet kunnen leveren.</p>
    <a href="/over-mij" class="btn">Over mij</a>
  </section>
</Layout>

<style>
  .hero {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    max-width: var(--max);
    margin: 0 auto;
    border-bottom: 1px solid #1e1e1e;
  }

  .hero p {
    margin-top: 1.5rem;
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .cta-section {
    border-top: 1px solid #1e1e1e;
  }

  .cta-section p {
    max-width: 600px;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
</style>
