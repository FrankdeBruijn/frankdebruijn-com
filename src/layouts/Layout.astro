---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Frank de Bruijn – Slowmotion, Drones & Thermografie" } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <title>{title} — Frank de Bruijn</title>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo">Frank de Bruijn<span class="logo-dot"></span></a>
      <button class="menu-toggle" aria-label="Menu" id="menuToggle">
        <span></span><span></span><span></span>
      </button>
      <ul id="navMenu">
        <li><a href="/over-mij" class={currentPath === "/over-mij" ? "active" : ""}>Over mij</a></li>
        <li><a href="/art-of-slowmotion" class={currentPath === "/art-of-slowmotion" ? "active" : ""}>Art of Slowmotion</a></li>
        <li><a href="/drone-operations" class={currentPath === "/drone-operations" ? "active" : ""}>Drone Operations</a></li>
        <li><a href="/thermography" class={currentPath === "/thermography" ? "active" : ""}>Thermography</a></li>
        <li><a href="/digital-services" class={currentPath === "/digital-services" ? "active" : ""}>Digital Services</a></li>
        <li><a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-main">
      <div class="footer-logos">
        <img src="/logos/artofslowmotion.png" alt="Art of Slowmotion" height="40" />
        <img src="/logos/warmtescan.png" alt="Warmtescan.nu" height="40" />
        <img src="/logos/droneoperations.png" alt="Drone Operations" height="40" />
        <img src="/logos/qtake.webp" alt="Qtake" height="40" />
        <img src="/logos/samsung.png" alt="Samsung" height="40" />
        <img src="/logos/davinci.png" alt="DaVinci Resolve" height="40" />
      </div>
      <div class="footer-info">
        <div class="footer-col">
          <h4>Info</h4>
          <a href="tel:+31612415418">+31(0) 6 12 41 54 18</a>
          <a href="mailto:Info@frankdebruijn.com">Info@frankdebruijn.com</a>
        </div>
        <div class="footer-col">
          <h4>Address</h4>
          <p>Krakenburg 23</p>
          <p>5341BM Oss, The Netherlands</p>
        </div>
        <div class="footer-col">
          <h4>Follow</h4>
          <a href="https://www.linkedin.com/in/frankdebruijn" target="_blank">LinkedIn</a>
          <a href="https://www.facebook.com/artofslowmotion" target="_blank">Facebook</a>
          <a href="https://www.instagram.com/frankdebruijnfilmmaker" target="_blank">Instagram</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2023 by Frank de Bruijn</p>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menuToggle');
    const menu = document.getElementById('navMenu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('open');
      toggle.classList.toggle('active');
    });
    // Close on link click (mobile)
    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        menu.classList.remove('open');
        toggle?.classList.remove('active');
      });
    });
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0a0a0a;
    --dark: #111;
    --mid: #1a1a1a;
    --text: #ffffff;
    --muted: #999;
    --white: #fff;
    --purple: #6c47ff;
    --max: 1200px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--text);
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 16px;
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  /* Header */
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  nav {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    gap: 2rem;
  }

  .logo {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--white);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 3px;
    flex-shrink: 0;
  }

  .logo-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    background: #5b7cf6;
    border-radius: 1px;
    margin-left: 1px;
    flex-shrink: 0;
  }

  nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-left: auto;
  }

  nav ul a {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.75);
    transition: color 0.2s;
    white-space: nowrap;
  }

  nav ul a:hover,
  nav ul a.active { color: var(--white); }

  /* Hamburger */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: all 0.25s;
    transform-origin: center;
  }

  .menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .menu-toggle.active span:nth-child(2) { opacity: 0; }
  .menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* Main */
  main { min-height: 100vh; }

  /* Footer */
  footer {
    background: var(--black);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 4rem 2rem 2rem;
  }

  .footer-main {
    max-width: var(--max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .footer-logos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
  }

  .footer-logos img {
    max-height: 40px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: 0.75;
  }

  .footer-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .footer-col a,
  .footer-col p {
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--white); }

  .footer-bottom {
    max-width: var(--max);
    margin: 2rem auto 0;
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* Shared page styles */
  .page-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8rem 2rem 5rem;
    position: relative;
    overflow: hidden;
    background: var(--dark);
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.4;
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    width: 100%;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .page-hero p {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .btn-outline {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid rgba(255,255,255,0.6);
    color: var(--white);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: transparent;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    font-family: inherit;
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.08);
    border-color: var(--white);
  }

  .section {
    max-width: var(--max);
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .section h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .body-text {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 680px;
  }

  .body-text + .body-text { margin-top: 1.25rem; }

  .divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-main { grid-template-columns: 1fr; gap: 3rem; }
    .footer-info { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    nav { padding: 0 1.25rem; }

    .menu-toggle { display: flex; }

    nav ul {
      display: none;
      position: fixed;
      top: 70px;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(10,10,10,0.98);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      margin: 0;
    }

    nav ul.open { display: flex; }

    nav ul a {
      font-size: 1.1rem;
      color: var(--white);
    }

    .footer-info { grid-template-columns: 1fr; }

    .section { padding: 4rem 1.25rem; }
    .page-hero { padding: 7rem 1.25rem 4rem; }
  }
</style>
